<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="c:\temp\internal-nlog.txt">

	<targets>
		<target xsi:type="File" name="xmlFile" fileName="${basedir}/App_Data/Logs/izintakip_log.xml" archiveAboveSize="5242880" maxArchiveFiles="10">
			<layout xsi:type="SimpleLayout">
				<text>
					<![CDATA[<logTime="${longdate}" level="${level:uppercase=true}" logger="${logger}" message="${message}" exception="${exception:format=toString,StackTrace}" />]]>
				</text>
			</layout>
		</target>
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="xmlFile" />
	</rules>
</nlog>